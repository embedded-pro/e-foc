{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Linux Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DISPLAY",
                    "value": "host.docker.internal:0.0"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Simulator GUI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/host/tools/simulator/app/Debug/e_foc.tool.simulator",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DISPLAY",
                    "value": "host.docker.internal:0.0"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Hardware Bridge GUI",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/host/tools/hardware_bridge/client/gui/main/Debug/e_foc.tool.hardware_bridge.bridge_client_gui",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DISPLAY",
                    "value": "host.docker.internal:0.0"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "CAN Commander (Docker)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/host/tools/can_commander/main/Debug/e_foc.tool.can_commander",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "DISPLAY",
                    "value": "host.docker.internal:0.0"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Embedded Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "external",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "both",
            "gdbTarget": "host.docker.internal:2334",
            "overrideLaunchCommands": [
                "monitor reset",
                "-target-download",
                "monitor reset"
            ],
            "overrideRestartCommands": [
                "monitor reset"
            ]
        },
        {
            "name": "HIL Tests",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Build HIL tests",
            "program": "${workspaceFolder}/build/host/integration_tests/hardware_in_the_loop/main/${input:hilBuildType}/e_foc.hil_tests",
            "args": [
                "--bridge-host",
                "host.docker.internal",
                "--serial-port",
                "5000",
                "--can-port",
                "5001",
                "--gdb-exe",
                "/usr/bin/gdb-multiarch",
                "--gdb-target",
                "host.docker.internal:2334",
                "--firmware-elf",
                "${workspaceFolder}/build/${input:boardType}/targets/hardware_test/main/${input:hilBuildType}/e_foc.hardware_test.main.elf",
                "${workspaceFolder}/integration_tests/hardware_in_the_loop/features"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
            "id": "boardType",
            "type": "pickString",
            "description": "Select board type for HIL tests and target firmware",
            "options": [
                "EK-TM4C1294XL",
                "EK-TM4C123GXL",
                "STM32F407G-DISC1",
                "NUCLEO-H563ZI"
            ],
            "default": "EK-TM4C1294XL"
        },
        {
            "id": "hilBuildType",
            "type": "pickString",
            "description": "Select build type for HIL tests and target firmware",
            "options": [
                "Debug",
                "Release",
                "RelWithDebInfo",
                "MinSizeRel"
            ],
            "default": "Debug"
        }
    ]
}
