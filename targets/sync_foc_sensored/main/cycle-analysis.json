{
    "path_name": "ADC ISR → FOC Position (worst case: inner + outer loop + all estimators) → PWM Output",
    "loop_rates_khz": [
        1,
        10,
        20
    ],
    "path_stages": [
        {
            "label": "ISR Entry (exception overhead)",
            "type": "exception_entry"
        },
        {
            "label": "ADC ISR + Callback Dispatch",
            "patterns": [
                "Adc0Sequence.*Handler",
                "InterruptTable::Invoke",
                "ImmediateInterruptHandler::Invoke"
            ]
        },
        {
            "label": "Encoder Read",
            "patterns": [
                "PlatformAdapter::Read",
                "QuadratureEncoderDecorator.*::Read",
                "QuadratureEncoder::Position",
                "QuadratureEncoder::Resolution"
            ]
        },
        {
            "label": "FOC Inner Loop (Calculate)",
            "entry": "FocPositionImpl::Calculate",
            "patterns": [
                "FocPositionImpl::Calculate",
                "FocWithSpeedLoop::CalculateInnerLoop",
                "Clarke::Forward",
                "Park::Forward",
                "Park::Inverse",
                "SpaceVectorModulation::Generate",
                "SpaceVectorModulation::Clip",
                "FastTrigonometry::Sine",
                "FastTrigonometry::Cosine",
                "PidIncrementalBase.*::Process",
                "PidIncrementalBase.*::Clamp",
                "PidIncrementalSynchronous.*::Process",
                "PidIncrementalSynchronous.*::SetPoint",
                "PositionWithWrapAround",
                "std::array<float.*>::operator\\[\\]",
                "std::clamp",
                "std::max<float>",
                "std::min<float>"
            ]
        },
        {
            "label": "FOC Outer Loop (LowPriorityHandler)",
            "patterns": [
                "FocPositionImpl::LowPriorityHandler",
                "FocWithSpeedLoop::LowPriorityHandler",
                "PidIncrementalSynchronous.*::Process",
                "PidIncrementalSynchronous.*::SetPoint",
                "PositionWithWrapAround"
            ]
        },
        {
            "label": "Online Mechanical Estimator (RLS)",
            "required": false,
            "patterns": [
                "FocWithSpeedLoop::UpdateOnlineMechanicalEstimator",
                "RealTimeFrictionAndInertiaEstimator::Update",
                "RecursiveLeastSquares.*::Update",
                "ClarkePark::Forward"
            ]
        },
        {
            "label": "Online Electrical Estimator (RLS)",
            "required": false,
            "patterns": [
                "FocWithSpeedLoop::UpdateOnlineElectricalEstimator",
                "RealTimeResistanceAndInductanceEstimator::Update",
                "RealTimeResistanceAndInductanceEstimator::ComputeEstimate",
                "RecursiveLeastSquares.*::Update"
            ]
        },
        {
            "label": "PWM Output",
            "patterns": [
                "PlatformAdapter::ThreePhasePwmOutput",
                "SynchronousPwm::Start.*Percent.*Percent.*Percent",
                "SynchronousPwm::SetComparator",
                "SynchronousPwm::Sync"
            ]
        },
        {
            "label": "ISR Exit (exception return)",
            "type": "exception_exit"
        }
    ]
}
